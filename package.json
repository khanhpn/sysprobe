{
  "name": "sysprobe",
  "version": "0.1.3",
  "description": "Small TypeScript system probe library and CLI.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khanhpham/sysprobe.git"
  },
  "bugs": {
    "url": "https://github.com/khanhpham/sysprobe/issues"
  },
  "homepage": "https://github.com/khanhpham/sysprobe#readme",
  "license": "MIT",
  "bin": {
    "sysprobe": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "systeminformation": "^5.27.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.12.4"
}
